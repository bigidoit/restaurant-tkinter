import tkinter as tk
import sqlite3
from datetime import datetime
from Receipt import Receipt
from Configurations import Configurations as config

class Submit:
    def __init__(self, order_num, menu_dict, root):
        x_pos = config.SUBMIT_POS[0]
        y_pos = config.SUBMIT_POS[1]

        self.connection = sqlite3.connect("RestaurantDB")
        self.cursor = self.connection.cursor()

        self.order_num = order_num

        self.menu_dict = menu_dict
        self.button = tk.Button(root, text = "Submit Order", font = config.FONT, fg = config.TEXT_COLOR, bg = "dark gray", width = 12, command = self.save_changes)
        self.button.place(x = x_pos, y = y_pos)
        
    def save_changes(self):
        time = str(datetime.now())

        set_text = "date = ?, tip = ?, " + ", ".join([f"{item} = ?" for item in config.ITEMS.keys()])

        params = [time]

        for info in self.menu_dict.values():
            amount = info[0]

            params.append(amount)

        update_values = f"UPDATE orders SET {set_text} WHERE id = {self.order_num}"
        
        self.cursor.execute(update_values, tuple(params))

        self.connection.commit()

        get_all = """SELECT * FROM orders"""

        self.cursor.execute(get_all)
        orders = self.cursor.fetchall()

        print(orders)

        print("Submitted order " + str(self.order_num))
